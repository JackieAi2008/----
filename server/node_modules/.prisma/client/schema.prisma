// Prisma Schema - 中集智历
// 数据库：SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 数据模型 ====================

// 用户表
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nickname  String
  avatar    String?
  bio       String?
  isAdmin   Boolean  @default(false)
  isBanned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  securityAnswers   SecurityAnswer[]
  ownedProjects     Project[]          @relation("ProjectOwner")
  projectMembers    ProjectMember[]
  sentInvites       ProjectInvite[]    @relation("Inviter")
  receivedInvites   ProjectInvite[]    @relation("Invitee")
  assignedTasks     Task[]             @relation("TaskAssignee")
  createdTasks      Task[]             @relation("TaskCreator")
  taskCollaborators TaskCollaborator[]
  comments          Comment[]
  attachments       Attachment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  pushSubscriptions PushSubscription[]
  taskTemplates     TaskTemplate[]
}

// 安全答案表
model SecurityAnswer {
  id            String   @id @default(uuid())
  userId        String
  questionIndex Int
  answer        String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionIndex])
}

// 项目表
model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  cover       String?
  visibility  String    @default("PRIVATE") // PUBLIC, PRIVATE
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // 关联
  owner      User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    ProjectMember[]
  invites    ProjectInvite[]
  categories TaskCategory[]
  tasks      Task[]

  @@index([visibility])
}

// 项目成员表
model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER") // OWNER, MEMBER
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// 项目邀请表
model ProjectInvite {
  id        String   @id @default(uuid())
  projectId String
  inviterId String
  inviteeId String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User    @relation("Invitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([status])
}

// 任务类别表
model TaskCategory {
  id        String   @id @default(uuid())
  projectId String?
  name      String
  color     String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  templates TaskTemplate[]
}

// 任务表
model Task {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String?
  startDate   DateTime?
  dueDate     DateTime
  categoryId  String?
  assigneeId  String
  priority    String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE, CANCELLED
  deliverable String?
  tags        String? // JSON array of tags (SQLite doesn't support String[])
  reminder    String? // FIFTEEN_MIN, ONE_HOUR, ONE_DAY, THREE_DAYS
  repeat      String? // DAILY, WEEKLY, MONTHLY, YEARLY
  creatorId   String
  isArchived  Boolean   @default(false) // 是否已归档
  archivedAt  DateTime? // 归档时间
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category      TaskCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assignee      User               @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creator       User               @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  collaborators TaskCollaborator[]
  comments      Comment[]
  attachments   Attachment[]

  @@index([dueDate])
  @@index([status])
  @@index([isArchived])
}

// 任务协作者表
model TaskCollaborator {
  id     String @id @default(uuid())
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

// 评论表
model Comment {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  content   String
  mentions  String? // JSON array of user IDs
  replyToId String?
  images    String? // JSON array of image URLs
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// 附件表
model Attachment {
  id           String   @id @default(uuid())
  taskId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  uploaderId   String
  createdAt    DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

// 通知表
model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String // TASK_ASSIGNED, TASK_DUE, TASK_STATUS_CHANGED, etc.
  title       String
  content     String?
  relatedType String? // TASK, PROJECT, COMMENT, USER
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
}

// 审计日志表
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String // USER_LOGIN, PROJECT_CREATE, etc.
  targetType String // USER, PROJECT, TASK, COMMENT
  targetId   String?
  details    String? // JSON
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([createdAt])
}

// 推送订阅表
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  keys      String // JSON: { p256dh: ..., auth: ... }
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 任务模板表
model TaskTemplate {
  id              String   @id @default(uuid())
  title           String
  description     String?
  priority        String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  categoryId      String?
  defaultAssignee String?
  creatorId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator  User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  category TaskCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([creatorId])
}
