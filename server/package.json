    "test:watch": "NODE_ENV=test jest --watch",
    "test:auth": "NODE_ENV=test jest src/__tests__/auth.test.ts",
    "test:project": "NODE_ENV=test jest src/__tests__/project.test.ts",
    "test:task": "NODE_ENV=test jest src/__tests__/task.test.ts",
    "test:export": "NODE_ENV=test jest src/__tests__/export.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
