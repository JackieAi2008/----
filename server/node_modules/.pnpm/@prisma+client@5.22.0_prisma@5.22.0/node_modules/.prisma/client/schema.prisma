generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attachment {
  id           String   @id
  taskId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  uploaderId   String
  createdAt    DateTime @default(now())
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id
  userId     String
  action     String
  targetType String
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([targetType, targetId])
}

model Comment {
  id        String    @id
  taskId    String
  userId    String
  content   String
  mentions  String?
  replyToId String?
  images    String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Department {
  id          String    @id
  name        String    @unique
  description String?
  adminId     String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  admin       User      @relation("Department_adminIdToUser", fields: [adminId], references: [id], onDelete: Cascade)
  projects    Project[]
  members     User[]    @relation("User_departmentIdToDepartment")

  @@index([name])
}

model Notification {
  id          String   @id
  userId      String
  type        String
  title       String
  content     String?
  relatedType String?
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
}

model Project {
  id           String          @id
  name         String
  description  String?
  cover        String?
  visibility   String          @default("PRIVATE")
  ownerId      String
  departmentId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  department   Department?     @relation(fields: [departmentId], references: [id])
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invites      ProjectInvite[]
  members      ProjectMember[]
  tasks        Task[]
  categories   TaskCategory[]

  @@index([departmentId])
  @@index([visibility])
}

model ProjectInvite {
  id        String   @id
  projectId String
  inviterId String
  inviteeId String
  status    String   @default("PENDING")
  expiresAt DateTime
  createdAt DateTime @default(now())
  invitee   User     @relation("ProjectInvite_inviteeIdToUser", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter   User     @relation("ProjectInvite_inviterIdToUser", fields: [inviterId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ProjectMember {
  id        String   @id
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PushSubscription {
  id        String   @id
  userId    String
  endpoint  String   @unique
  keys      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityAnswer {
  id            String   @id
  userId        String
  questionIndex Int
  answer        String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionIndex])
}

model Task {
  id            String             @id
  projectId     String
  title         String
  description   String?
  startDate     DateTime?
  dueDate       DateTime
  categoryId    String?
  assigneeId    String
  priority      String             @default("MEDIUM")
  status        String             @default("TODO")
  visibility    String             @default("PRIVATE") // PUBLIC/PRIVATE - 任务可见性
  deliverable   String?
  tags          String?
  reminder      String?
  repeat        String?
  creatorId     String
  isArchived    Boolean            @default(false)
  archivedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?
  attachments   Attachment[]
  comments      Comment[]
  creator       User               @relation("Task_creatorIdToUser", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee      User               @relation("Task_assigneeIdToUser", fields: [assigneeId], references: [id], onDelete: Cascade)
  category      TaskCategory?      @relation(fields: [categoryId], references: [id])
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collaborators TaskCollaborator[]

  @@index([isArchived])
  @@index([status])
  @@index([dueDate])
  @@index([visibility])
}

model TaskCategory {
  id        String         @id
  projectId String?
  name      String
  color     String
  isSystem  Boolean        @default(false)
  createdAt DateTime       @default(now())
  tasks     Task[]
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templates TaskTemplate[]
}

model TaskCollaborator {
  id     String @id
  taskId String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskTemplate {
  id              String        @id
  title           String
  description     String?
  priority        String        @default("MEDIUM")
  categoryId      String?
  defaultAssignee String?
  creatorId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  category        TaskCategory? @relation(fields: [categoryId], references: [id])
  creator         User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model User {
  id                 String             @id
  email              String             @unique
  password           String
  nickname           String
  avatar             String?
  bio                String?
  isAdmin            Boolean            @default(false)
  isBanned           Boolean            @default(false)
  departmentId       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  attachments        Attachment[]
  auditLogs          AuditLog[]
  comments           Comment[]
  managedDepartment  Department?        @relation("Department_adminIdToUser")
  notifications      Notification[]
  ownedProjects      Project[]
  receivedInvites    ProjectInvite[]    @relation("ProjectInvite_inviteeIdToUser")
  sentInvites        ProjectInvite[]    @relation("ProjectInvite_inviterIdToUser")
  projectMemberships ProjectMember[]
  pushSubscriptions  PushSubscription[]
  securityAnswers    SecurityAnswer[]
  createdTasks       Task[]             @relation("Task_creatorIdToUser")
  assignedTasks      Task[]             @relation("Task_assigneeIdToUser")
  taskCollaborations TaskCollaborator[]
  taskTemplates      TaskTemplate[]
  department         Department?        @relation("User_departmentIdToDepartment", fields: [departmentId], references: [id])

  @@index([departmentId])
}
