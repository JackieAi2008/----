    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "@types/pdfkit": "^0.13.4",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "prisma": "^5.8.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
