generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  uploaderId   String
  createdAt    DateTime @default(now())
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([targetType, targetId])
}

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  content   String
  type      String    @default("COMMENT")  // 'COMMENT' | 'PROGRESS'
  mentions  String?
  replyToId String?
  images    String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type])
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  adminId     String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       User      @relation("Department_adminIdToUser", fields: [adminId], references: [id], onDelete: Cascade)
  projects    Project[]
  members     User[]    @relation("User_departmentIdToDepartment")

  @@index([name])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  content     String?
  relatedType String?
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?
  cover         String?
  visibility    String          @default("PRIVATE")
  category      String?         // PARTY_BUILDING | TRADE_UNION | COMMUNIST_YOUTH_LEAGUE | PUBLIC_WELFARE | COMPREHENSIVE
  ownerId       String
  departmentId  String?
  isArchived    Boolean         @default(false)
  archivedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  department    Department?     @relation(fields: [departmentId], references: [id])
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invites       ProjectInvite[]
  summaries     ProjectSummary[]
  members       ProjectMember[]
  tasks         Task[]
  categories    TaskCategory[]
  evaluations   Evaluation[]

  @@index([departmentId])
  @@index([visibility])
  @@index([isArchived])
  @@index([category])
}

model ProjectInvite {
  id         String   @id @default(cuid())
  projectId  String
  inviterId  String
  inviteeId  String
  status     String   @default("PENDING")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  invitee    User     @relation("ProjectInvite_inviteeIdToUser", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter    User     @relation("ProjectInvite_inviterIdToUser", fields: [inviterId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityAnswer {
  id            String   @id @default(cuid())
  userId        String
  questionIndex Int
  answer        String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionIndex])
}

model Task {
  id             String             @id @default(cuid())
  projectId      String
  title          String
  description    String?
  startDate      DateTime?
  dueDate        DateTime
  categoryId     String?
  assigneeId     String
  priority       String             @default("IMPORTANT_URGENT")  // IMPORTANT_URGENT | IMPORTANT_NOT_URGENT | URGENT_NOT_IMPORTANT | NOT_IMPORTANT_NOT_URGENT
  status         String             @default("TODO")
  visibility     String             @default("PUBLIC")  // 固定为公开
  deliverable    String?
  tags           String?
  reminder       String?
  repeat         String?
  creatorId      String
  isArchived     Boolean            @default(false)
  archivedAt     DateTime?
  completedAt    DateTime?          // 完成时间，status→DONE 时自动记录
  completedBy    String?            // 完成操作人 ID
  completionNote String?            // 完成备注（用户填写）
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  attachments    Attachment[]
  comments       Comment[]
  creator        User               @relation("Task_creatorIdToUser", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee       User               @relation("Task_assigneeIdToUser", fields: [assigneeId], references: [id], onDelete: Cascade)
  category       TaskCategory?      @relation(fields: [categoryId], references: [id])
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collaborators  TaskCollaborator[]
  evaluations    Evaluation[]

  @@index([isArchived])
  @@index([status])
  @@index([dueDate])
  @@index([visibility])
}

model TaskCategory {
  id           String         @id @default(cuid())
  projectId    String?
  name         String
  color        String
  isSystem     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  tasks        Task[]
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templates    TaskTemplate[]
}

model TaskCollaborator {
  id     String @id @default(cuid())
  taskId String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskTemplate {
  id              String        @id @default(cuid())
  title           String
  description     String?
  priority        String        @default("IMPORTANT_URGENT")
  categoryId      String?
  defaultAssignee String?
  creatorId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  category        TaskCategory? @relation(fields: [categoryId], references: [id])
  creator         User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model User {
  id                                          String             @id @default(cuid())
  email                                       String             @unique
  password                                    String
  nickname                                    String?
  avatar                                      String?
  bio                                         String?
  isAdmin                                     Boolean            @default(false)
  isBanned                                    Boolean            @default(false)
  departmentId                                String?
  createdAt                                   DateTime           @default(now())
  updatedAt                                   DateTime           @updatedAt
  attachments                                 Attachment[]
  auditLogs                                   AuditLog[]
  comments                                    Comment[]
  managedDepartment                           Department?        @relation("Department_adminIdToUser")
  notifications                               Notification[]
  ownedProjects                               Project[]
  receivedInvites                             ProjectInvite[]    @relation("ProjectInvite_inviteeIdToUser")
  sentInvites                                 ProjectInvite[]    @relation("ProjectInvite_inviterIdToUser")
  projectMemberships                          ProjectMember[]
  authoredSummaries                           ProjectSummary[]
  pushSubscriptions                           PushSubscription[]
  securityAnswers                             SecurityAnswer[]
  createdTasks                                Task[]             @relation("Task_creatorIdToUser")
  assignedTasks                               Task[]             @relation("Task_assigneeIdToUser")
  taskCollaborations                          TaskCollaborator[]
  taskTemplates                               TaskTemplate[]
  department                                  Department?        @relation("User_departmentIdToDepartment", fields: [departmentId], references: [id])
  givenEvaluations                            Evaluation[]       @relation("Evaluation_evaluator")
  receivedEvaluations                         Evaluation[]       @relation("Evaluation_target")

  @@index([departmentId])
}


model ProjectSummary {
  id            String   @id @default(cuid())
  projectId     String
  authorId      String
  title         String
  content       String
  summaryType   String   @default("WORK") // WORK | AI
  aiContent     String?
  aiGeneratedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([authorId])
}
model Evaluation {
  id           String   @id @default(cuid())
  taskId       String
  evaluatorId  String   // 评价人（全局管理者）
  targetUserId String   // 被评价人
  projectId    String   // 所属项目
  rating       Int      // 1-5 星
  comment      String?  // 评价备注
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  evaluator   User    @relation("Evaluation_evaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  targetUser  User    @relation("Evaluation_target", fields: [targetUserId], references: [id], onDelete: Cascade)
  task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project @relation(fields: [projectId], references: [id])

  @@unique([taskId, targetUserId, evaluatorId])
  @@index([evaluatorId])
  @@index([targetUserId])
  @@index([projectId])
}

model DeliverableOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
