generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attachment {
  id           String   @id
  taskId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  uploaderId   String
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  Task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id
  userId     String
  action     String
  targetType String
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([targetType, targetId])
}

model Comment {
  id        String    @id
  taskId    String
  userId    String
  content   String
  mentions  String?
  replyToId String?
  images    String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Department {
  id                                 String    @id
  name                               String    @unique
  description                        String?
  adminId                            String    @unique
  createdAt                          DateTime  @default(now())
  updatedAt                          DateTime
  User_Department_adminIdToUser      User      @relation("Department_adminIdToUser", fields: [adminId], references: [id], onDelete: Cascade)
  Project                            Project[]
  User_User_departmentIdToDepartment User[]    @relation("User_departmentIdToDepartment")

  @@index([name])
}

model Notification {
  id          String   @id
  userId      String
  type        String
  title       String
  content     String?
  relatedType String?
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
}

model Project {
  id            String          @id
  name          String
  description   String?
  cover         String?
  visibility    String          @default("PRIVATE")
  ownerId       String
  departmentId  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?
  Department    Department?     @relation(fields: [departmentId], references: [id])
  User          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ProjectInvite ProjectInvite[]
  ProjectMember ProjectMember[]
  Task          Task[]
  TaskCategory  TaskCategory[]

  @@index([departmentId])
  @@index([visibility])
}

model ProjectInvite {
  id                                 String   @id
  projectId                          String
  inviterId                          String
  inviteeId                          String
  status                             String   @default("PENDING")
  expiresAt                          DateTime
  createdAt                          DateTime @default(now())
  User_ProjectInvite_inviteeIdToUser User     @relation("ProjectInvite_inviteeIdToUser", fields: [inviteeId], references: [id], onDelete: Cascade)
  User_ProjectInvite_inviterIdToUser User     @relation("ProjectInvite_inviterIdToUser", fields: [inviterId], references: [id], onDelete: Cascade)
  Project                            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ProjectMember {
  id        String   @id
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PushSubscription {
  id        String   @id
  userId    String
  endpoint  String   @unique
  keys      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityAnswer {
  id            String   @id
  userId        String
  questionIndex Int
  answer        String
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionIndex])
}

model Task {
  id                         String             @id
  projectId                  String
  title                      String
  description                String?
  startDate                  DateTime?
  dueDate                    DateTime
  categoryId                 String?
  assigneeId                 String
  priority                   String             @default("MEDIUM")
  status                     String             @default("TODO")
  deliverable                String?
  tags                       String?
  reminder                   String?
  repeat                     String?
  creatorId                  String
  isArchived                 Boolean            @default(false)
  archivedAt                 DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime
  deletedAt                  DateTime?
  Attachment                 Attachment[]
  Comment                    Comment[]
  User_Task_creatorIdToUser  User               @relation("Task_creatorIdToUser", fields: [creatorId], references: [id], onDelete: Cascade)
  User_Task_assigneeIdToUser User               @relation("Task_assigneeIdToUser", fields: [assigneeId], references: [id], onDelete: Cascade)
  TaskCategory               TaskCategory?      @relation(fields: [categoryId], references: [id])
  Project                    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TaskCollaborator           TaskCollaborator[]

  @@index([isArchived])
  @@index([status])
  @@index([dueDate])
}

model TaskCategory {
  id           String         @id
  projectId    String?
  name         String
  color        String
  isSystem     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  Task         Task[]
  Project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TaskTemplate TaskTemplate[]
}

model TaskCollaborator {
  id     String @id
  taskId String
  userId String
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  Task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskTemplate {
  id              String        @id
  title           String
  description     String?
  priority        String        @default("MEDIUM")
  categoryId      String?
  defaultAssignee String?
  creatorId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  TaskCategory    TaskCategory? @relation(fields: [categoryId], references: [id])
  User            User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model User {
  id                                          String             @id
  email                                       String             @unique
  password                                    String
  nickname                                    String
  avatar                                      String?
  bio                                         String?
  isAdmin                                     Boolean            @default(false)
  isBanned                                    Boolean            @default(false)
  departmentId                                String?
  createdAt                                   DateTime           @default(now())
  updatedAt                                   DateTime
  Attachment                                  Attachment[]
  AuditLog                                    AuditLog[]
  Comment                                     Comment[]
  Department_Department_adminIdToUser         Department?        @relation("Department_adminIdToUser")
  Notification                                Notification[]
  Project                                     Project[]
  ProjectInvite_ProjectInvite_inviteeIdToUser ProjectInvite[]    @relation("ProjectInvite_inviteeIdToUser")
  ProjectInvite_ProjectInvite_inviterIdToUser ProjectInvite[]    @relation("ProjectInvite_inviterIdToUser")
  ProjectMember                               ProjectMember[]
  PushSubscription                            PushSubscription[]
  SecurityAnswer                              SecurityAnswer[]
  Task_Task_creatorIdToUser                   Task[]             @relation("Task_creatorIdToUser")
  Task_Task_assigneeIdToUser                  Task[]             @relation("Task_assigneeIdToUser")
  TaskCollaborator                            TaskCollaborator[]
  TaskTemplate                                TaskTemplate[]
  Department_User_departmentIdToDepartment    Department?        @relation("User_departmentIdToDepartment", fields: [departmentId], references: [id])

  @@index([departmentId])
}
